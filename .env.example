# ============================================
# 应用服务配置
# ============================================

# API 服务配置
API_PORT=3001
API_HOST=localhost

# 前端配置
WEB_PORT=5173

# ============================================
# 依赖服务配置
# ============================================

# ───────────────────────────────────────────
# Ollama (嵌入服务)
# ───────────────────────────────────────────
#
# 快速启动:
#   npm run start:deps    # 自动启动所有依赖
#   npm run check:deps    # 检查依赖状态
#
# 手动安装:
#   macOS:   brew install ollama
#   Linux:   curl -fsSL https://ollama.com/install.sh | sh
#   Windows: https://ollama.com/download
#
# 手动启动:
#   ollama serve              # 启动服务
#   ollama pull nomic-embed-text  # 拉取嵌入模型
#
# 验证: curl http://127.0.0.1:11434/api/tags
#
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=30000

# Ollama 初始化重试配置
# 如果 Ollama 未运行，系统将在启动时重试指定次数
OLLAMA_INIT_RETRY_MAX_ATTEMPTS=3
OLLAMA_INIT_RETRY_DELAY=2000

# ───────────────────────────────────────────
# ChromaDB (向量数据库)
# ───────────────────────────────────────────
#
# 快速启动:
#   npm run start:deps    # 自动启动所有依赖（需要 Docker）
#   npm run check:deps    # 检查依赖状态
#
# 手动启动（Docker 推荐）:
#   docker run -d -p 8000:8000 --name local-rag-chroma chromadb/chroma
#
# 手动启动（Python）:
#   pip install chromadb
#   chroma-server --port 8000
#
# 验证: curl http://localhost:8000/api/v1/heartbeat
#
CHROMA_PATH=http://localhost:8000

# ChromaDB 查询超时（毫秒）
CHROMA_QUERY_TIMEOUT=5000

# ChromaDB 初始化重试配置
CHROMA_INIT_RETRY_MAX_ATTEMPTS=3
CHROMA_INIT_RETRY_DELAY=1000

# 存储路径
DATA_PATH=./apps/api/data
UPLOAD_PATH=./apps/api/uploads

# MCP Server
API_BASE_URL=http://localhost:3001
DATA_PATH=./apps/api/data

# 向量存储配置
VECTOR_STORE_TYPE=simple
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# 日志配置
LOG_DIR=logs
LOG_LEVEL=info
LOG_TO_CONSOLE=true
