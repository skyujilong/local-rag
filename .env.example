# API 服务配置
API_PORT=3001
API_HOST=localhost

# 前端配置
WEB_PORT=5173

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=30000

# ChromaDB 配置
# ChromaDB 需要单独运行服务器，请先启动 ChromaDB 服务器：
# - Docker: docker run -p 8000:8000 chromadb/chroma
# - Python: pip install chromadb && chroma-server --port 8000
CHROMA_PATH=http://localhost:8000

# 存储路径
DATA_PATH=./apps/api/data
UPLOAD_PATH=./apps/api/uploads

# MCP Server
API_BASE_URL=http://localhost:3001
DATA_PATH=./apps/api/data

# 向量存储配置
VECTOR_STORE_TYPE=simple
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# 日志配置
LOG_DIR=logs
LOG_LEVEL=info
LOG_TO_CONSOLE=true
