# API 服务配置
API_PORT=3001
API_HOST=localhost

# 前端配置
WEB_PORT=5173

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# ChromaDB 配置 (可选，不使用则用简单向量存储)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# 存储路径
DATA_PATH=./apps/api/data
UPLOAD_PATH=./apps/api/uploads

# MCP Server
API_BASE_URL=http://localhost:3001
DATA_PATH=./apps/api/data

# 向量存储配置
VECTOR_STORE_TYPE=simple
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# 日志配置
LOG_DIR=logs
LOG_LEVEL=info
LOG_TO_CONSOLE=true
