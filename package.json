{
  "name": "local-rag",
  "version": "1.0.0",
  "private": true,
  "description": "本地知识库系统 - 基于 LlamaIndex 的 RAG 应用",
  "scripts": {
    "dev": "pnpm --filter @local-rag/shared build && pnpm --filter @local-rag/nuxt-app dev",
    "dev:nuxt": "pnpm --filter @local-rag/nuxt-app dev",
    "dev:legacy": "concurrently -n \"WEB,API\" -c \"bgBlue.bold,bgGreen.bold\" \"pnpm --filter @local-rag/web dev\" \"pnpm --filter @local-rag/api dev\"",
    "dev:web": "pnpm --filter @local-rag/web dev",
    "dev:api": "pnpm --filter @local-rag/api dev",
    "dev:mcp": "pnpm --filter @local-rag/mcp-server dev",
    "kill": "pkill -f 'concurrently' && pkill -f 'tsx.*watch' && pkill -f 'vite' || pkill -f 'nuxt' || true",
    "build": "pnpm --filter @local-rag/nuxt-app build",
    "build:nuxt": "pnpm --filter @local-rag/nuxt-app build",
    "build:legacy": "pnpm -r build",
    "build:web": "pnpm --filter @local-rag/web build",
    "build:api": "pnpm --filter @local-rag/api build",
    "build:mcp": "pnpm --filter @local-rag/mcp-server build",
    "lint": "pnpm -r lint",
    "install:all": "pnpm -r install",
    "install:web": "pnpm --filter @local-rag/web install",
    "install:api": "pnpm --filter @local-rag/api install",
    "install:mcp": "pnpm --filter @local-rag/mcp-server install",
    "install:nuxt": "pnpm --filter @local-rag/nuxt-app install",
    "install:shared": "pnpm --filter @local-rag/shared install",
    "install:config": "pnpm --filter @local-rag/config install",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/dist packages/*/node_modules",
    "fresh": "pnpm clean && pnpm install"
  },
  "keywords": [
    "rag",
    "llamaindex",
    "mcp",
    "vue3",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2",
    "eslint": "^9.17.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
