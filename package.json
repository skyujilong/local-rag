{
  "name": "devrag-cli",
  "version": "1.0.0",
  "description": "Local RAG knowledge base with MCP integration for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "devrag-cli": "./dist/cli.js"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "env": "bash scripts/env.sh",
    "dev": "bash scripts/dev.sh",
    "dev:server": "tsx watch src/server/cli.ts",
    "dev:client": "cd src/client && npm run dev",
    "build": "bash scripts/build.sh",
    "build:shared": "tsup src/shared --watch",
    "start": "bash scripts/start.sh",
    "check:deps": "bash scripts/check-deps.sh",
    "start:deps": "bash scripts/start-deps.sh",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json,md}\"",
    "typecheck": "tsc --noEmit && cd src/client && pnpm exec vue-tsc --noEmit",
    "logs": "node scripts/view-logs.js",
    "logs:follow": "node scripts/view-logs.js --follow",
    "logs:error": "node scripts/view-logs.js --error",
    "logs:json": "node scripts/view-logs.js --json"
  },
  "keywords": [
    "rag",
    "mcp",
    "claude",
    "knowledge-base",
    "vector-search",
    "local-llm"
  ],
  "author": "devrag-cli",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.11.0",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "better-sqlite3": "^12.8.0",
    "chromadb": "^1.8.1",
    "commander": "^12.0.0",
    "hono": "^4.0.0",
    "isomorphic-dompurify": "^3.7.1",
    "jsdom": "^29.0.1",
    "ollama": "^0.5.0",
    "playwright": "^1.42.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/compiler-sfc": "^3.4.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.21.0",
    "naive-ui": "^2.38.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vitest": "^1.2.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  }
}
